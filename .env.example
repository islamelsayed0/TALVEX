# Talvex environment variables.
# Copy to .env.local and fill in real values. Never commit .env.local.
# Anything prefixed NEXT_PUBLIC_ is shipped to the browser, so it must never
# hold a secret.

# --- Clerk (auth + organizations) -------------------------------------------
# Both are printed by `clerk env pull`, or found in the Clerk dashboard.
# Safe for the browser: identifies your Clerk instance, grants nothing.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Server only. Full admin access to your Clerk instance.
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Route paths, not secrets. Without these, a signed out user hitting a
# protected route is sent to Clerk's hosted account portal instead of the
# sign in page in this app.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Server only. Verifies webhook deliveries on /api/webhooks/clerk; the
# signature is that route's only authentication. From the Clerk dashboard
# webhook endpoint (production) or `clerk webhooks` (local development).
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase (database) -----------------------------------------------------
# Your project's API endpoint.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Safe for the browser: every request it makes is still filtered by RLS.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
# Server only. BYPASSES ROW LEVEL SECURITY entirely. Use only where there is
# genuinely no tenant context (webhooks, cron, migrations). Never import this
# into a client component.
SUPABASE_SERVICE_ROLE_KEY=

# --- Cron (monitor checks) ---------------------------------------------------
# Server only. When set on the Vercel project, Vercel Cron sends it as a
# bearer token on every invocation of /api/cron/check-monitors, and the route
# rejects any request without it. Generate a long random value, for example:
# openssl rand -hex 32
CRON_SECRET=
